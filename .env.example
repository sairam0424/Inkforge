# LLM Provider: "bedrock" (default) or "anthropic"
LLM_PROVIDER=bedrock

# AWS Bedrock credentials (base64-encoded or raw)
BEDROCK_ACCESS_KEY_ID=
BEDROCK_SECRET_ACCESS_KEY=
BEDROCK_REGION=us-east-1

# Direct Anthropic API (only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Output paths (relative to Inkforge/ repo root)
INKFORGE_CONTENT_DIR=content/articles
INKFORGE_ANVILRY_NOTES_DIR=../Anvilry/sairam-dev/content/notes

# Publishing
DEVTO_API_KEY=
HASHNODE_API_KEY=
HASHNODE_PUBLICATION_ID=

# Canonical base URL for cross-post attribution
INKFORGE_CANONICAL_BASE=https://sairam.dev/notes
