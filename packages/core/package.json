{
  "name": "@inkforge/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Inkforge generation pipeline engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./publishers/devto": {
      "import": "./dist/publishers/devto.js",
      "types": "./dist/publishers/devto.d.ts"
    },
    "./publishers/hashnode": {
      "import": "./dist/publishers/hashnode.js",
      "types": "./dist/publishers/hashnode.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.30.2",
    "@anthropic-ai/sdk": "^0.104.1",
    "zod": "^3.25.76",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
