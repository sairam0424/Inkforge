{
  "name": "@inkforge/cli",
  "version": "0.1.1",
  "type": "module",
  "description": "Inkforge CLI — generate and publish articles from the terminal",
  "bin": {
    "inkforge": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@inkforge/core": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.2.0",
    "@inquirer/prompts": "^7.5.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
